<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:titleTextColor="@color/white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Tipo -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tipo" android:textColor="@color/text_secondary"
                android:textSize="12sp" android:layout_marginBottom="6dp"/>

            <RadioGroup
                android:id="@+id/rg_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rb_receita"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💚 Receita"
                    android:textSize="15sp"
                    android:button="@null"
                    android:background="@drawable/radio_selector_green"
                    android:gravity="center"
                    android:padding="12dp"/>

                <RadioButton
                    android:id="@+id/rb_despesa"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="❤️ Despesa"
                    android:textSize="15sp"
                    android:button="@null"
                    android:background="@drawable/radio_selector_red"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_marginStart="8dp"/>
            </RadioGroup>

            <!-- Valor -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Valor (R$)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textSize="18sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Categoria -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Categoria" android:textColor="@color/text_secondary"
                android:textSize="12sp" android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinner_category"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_background"
                android:popupBackground="@color/card_bg"
                android:layout_marginBottom="16dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>

            <!-- Data -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Data" android:textColor="@color/text_secondary"
                android:textSize="12sp" android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_background"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="16dp"/>

            <!-- Descrição -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Descrição (opcional)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="3"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Seção Parcelamento (visível só para Despesa) -->
            <LinearLayout
                android:id="@+id/section_installment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <CheckBox
                    android:id="@+id/cb_installment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Compra parcelada?"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_installment_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Número de parcelas"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_installment_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Resumo do parcelamento -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_installment_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="@color/card_bg"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tv_installment_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/tv_installment_last"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- Botão Salvar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="SALVAR TRANSAÇÃO"
                android:textSize="15sp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
